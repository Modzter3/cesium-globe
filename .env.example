# Copy to .env.local (never commit .env.local).
# Rotate any key that was pasted into chat or committed by mistake.
#
# Use exact names, no spaces around =.
# Quotes are optional; use straight " not smart quotes.

# FlightAware AeroAPI — https://www.flightaware.com/commercial/aeroapi/
FLIGHTAWARE_API_KEY=

# AISstream real-time AIS — free tier at https://aisstream.io
# Sign up, create an API key, paste it here, then restart the dev server.
AISSTREAM_API_KEY=

# ACLED armed conflict event data — free at https://acleddata.com/register/
# Use the email + password from your myACLED account (OAuth, no separate API key).
ACLED_EMAIL=
ACLED_PASSWORD=

# AI Intelligence Brief (SITREP) — pick ONE of the two below.
#
# Groq (free, very fast — recommended):
#   Sign up at https://console.groq.com → API Keys → Create
#   Model used: llama-3.1-8b-instant
GROQ_API_KEY=
#
# OpenAI (paid, ~$0.15 / 1M tokens with gpt-4o-mini):
#   https://platform.openai.com/api-keys
#   Model used: gpt-4o-mini
OPENAI_API_KEY=
